# Application
APP_NAME="swiggy-dineout-voice-agent"
APP_VERSION="1.0.0"
DEBUG=false

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dineout_voice"
# For local dev fallback: sqlite:///./dineout_voice.db

# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Groq (LLM)
GROQ_API_KEY=""

# Sarvam (TTS)
SARVAM_API_KEY=""

# Swiggy OAuth
SWIGGY_CLIENT_ID=""
SWIGGY_CLIENT_SECRET=""
SWIGGY_OAUTH_CALLBACK_URL="http://localhost:8000/auth/callback"

# ML Models
CLASSIFIER_MODEL_PATH="ml/models/classifier-int8.onnx"
MOONSHINE_MODEL_BASE="ml/models/moonshine-tiny-{lang}-int8.onnx"

# Logging
LOG_LEVEL="INFO"
LOG_DIR="logs"